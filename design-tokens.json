{
  "color": {
    "bg-void": "#010204",
    "glass": "rgba(255, 255, 255, 0.02)",
    "glass-border": "rgba(255, 255, 255, 0.08)",
    "electric-blue": "#00A3FF",
    "magma": "#FF5F00",
    "magma-end": "#A1665A",
    "white": "#FFFFFF",
    "black": "#000000",
    "text-muted": "rgba(255, 255, 255, 0.5)",
    "text-meta": "rgba(255, 255, 255, 0.4)"
  },
  "gradient": {
    "magma": "linear-gradient(135deg, #FF5F00 0%, #A1665A 100%)"
  },
  "font": {
    "display": "'Syne', sans-serif",
    "body": "'Inter', sans-serif"
  },
  "fontSize": {
    "h1": "6rem",
    "h2": "3.5rem",
    "h3": "1.8rem",
    "h4": "1.1rem",
    "h5": "0.75rem",
    "label": "0.7rem",
    "body": "1rem",
    "small": "0.9rem",
    "meta": "0.8rem"
  },
  "letterSpacing": {
    "h1": "-4px",
    "h2": "-2px",
    "h4": "3px",
    "h5": "4px",
    "label": "5px",
    "meta": "2px",
    "btn": "3px"
  },
  "spacing": {
    "xs": "0.5rem",
    "sm": "1rem",
    "md": "1.5rem",
    "lg": "2rem",
    "xl": "3rem",
    "2xl": "4rem",
    "3xl": "8rem"
  },
  "blur": {
    "glass": "40px",
    "leak": "180px"
  },
  "radius": {
    "btn": "2px",
    "panel": "0px"
  },
  "transition": {
    "smooth": "all 0.6s cubic-bezier(0.19, 1, 0.22, 1)",
    "fast": "all 0.3s ease"
  },
  "opacity": {
    "glass": "0.07",
    "muted": "0.5",
    "meta": "0.4",
    "inactive-tab": "0.3"
  },
  "animation": {
    "orbit-duration": "40s",
    "scan-duration": "5s"
  }
}
